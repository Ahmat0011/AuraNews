<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AuraNews.ViewModels"
             x:Class="AuraNews.Views.DiscoverPage"
             Title="Entdecken"
             BackgroundColor="#121212">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Nachrichtenanbieter" FontSize="24" FontAttributes="Bold" TextColor="White" />
            <Label Text="Füge die besten deutschen Quellen mit einem Klick zu deinem Feed hinzu." FontSize="14" TextColor="Gray" Margin="0,-10,0,10" />

            <CollectionView ItemsSource="{Binding RecommendedProviders}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="15" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="15" BackgroundColor="#1E1E1E" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Image Grid.Column="0" Source="{Binding IconUrl}" WidthRequest="40" HeightRequest="40" VerticalOptions="Center" Margin="0,0,15,0">
                                    <Image.Clip>
                                        <EllipseGeometry Center="20,20" RadiusX="20" RadiusY="20" />
                                    </Image.Clip>
                                </Image>

                                <Label Grid.Column="1" Text="{Binding Name}" TextColor="White" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />

                                <Button Grid.Column="2" Text="+ Abonnieren" FontSize="12" FontAttributes="Bold" TextColor="White" BackgroundColor="DarkCyan" CornerRadius="20" HeightRequest="35" Padding="15,0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:DiscoverViewModel}}, Path=SubscribeToProviderCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <BoxView HeightRequest="1" Color="#333333" Margin="0,10" />

            <Label Text="Deine Abos" FontSize="20" FontAttributes="Bold" TextColor="White" />
            <CollectionView ItemsSource="{Binding FollowedSources}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="*, Auto" Margin="0,5">
                            <Label Grid.Column="0" Text="{Binding Name}" TextColor="LightGray" VerticalOptions="Center" />

                            <Button Grid.Column="1" Text="Entfernen" FontSize="11" TextColor="#FF4444" BackgroundColor="Transparent" 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:DiscoverViewModel}}, Path=UnfollowSourceCommand}" CommandParameter="{Binding .}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>