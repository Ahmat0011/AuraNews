<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AuraNews.ViewModels"
             x:Class="AuraNews.Views.SettingsPage"
             Title="Mein Profil"
             BackgroundColor="#121212">



    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <VerticalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,20,0,30">

                <Border WidthRequest="100" HeightRequest="100" 
                        StrokeThickness="0" 
                        StrokeShape="RoundRectangle 50"
                        HorizontalOptions="Center"
                        BackgroundColor="#1E1E1E">

                    <Image Source="dotnet_bot.png" 
                           Aspect="AspectFill"
                           Margin="20"
                           Opacity="0.5"/>
                </Border>

                <Label Text="{Binding UserName}" 
                       FontSize="24" 
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"/>

                <Label Text="{Binding UserStatus}" 
                       FontSize="14" 
                       TextColor="#888888"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <Button TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    HeightRequest="50"
                    Margin="0,0,0,20">
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsLoggedIn}" Value="True">
                        <Setter Property="Text" Value="Abmelden" />
                        <Setter Property="Command" Value="{Binding LogoutCommand}" />
                        <Setter Property="BackgroundColor" Value="#D32F2F" />
                    </DataTrigger>
                    <DataTrigger TargetType="Button" Binding="{Binding IsLoggedIn}" Value="False">
                        <Setter Property="Text" Value="Anmelden / Registrieren" />
                        <Setter Property="Command" Value="{Binding OpenLoginCommand}" />
                        <Setter Property="BackgroundColor" Value="#008080" />
                    </DataTrigger>
                </Button.Triggers>
            </Button>

            <Border BackgroundColor="#1E1E1E" 
                    StrokeThickness="0" 
                    StrokeShape="RoundRectangle 16"
                    Padding="20">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Meine Interessen" 
                           TextColor="White" 
                           FontAttributes="Bold" 
                           FontSize="16"/>
                    <Label Text="Hier wird die KI demnächst anzeigen, was du am liebsten liest, um dir bessere Vorschläge zu machen." 
                           TextColor="#AAAAAA" 
                           FontSize="14"/>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#1E1E1E" 
                    StrokeThickness="0" 
                    StrokeShape="RoundRectangle 16"
                    Padding="20">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Blockierte Themen verwalten" 
                           TextColor="White" 
                           FontAttributes="Bold" 
                           FontSize="16"/>
                    <Label Text="Themen, die demnächst in der Cloud synchronisiert werden." 
                           TextColor="#AAAAAA" 
                           FontSize="14"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
